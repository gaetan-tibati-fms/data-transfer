  <node componentName="tSendMail" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="224" posY="192">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tSendMail_1" show="false"/>
    <elementParameter field="TEXT" name="TO" value="&quot;tmabi@fms-ea.com&quot;"/>
